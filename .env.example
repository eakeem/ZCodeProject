# ============================================================
# Memorial App — Environment Variables
# ============================================================
# Copy this file to `.env.local` and fill in your values.
# The app runs WITHOUT these (local file store + demo login)
# so you can develop immediately. Set them to go fully live.
# ============================================================

# --- Supabase (database + auth) ---
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# anon public key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role key (server only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudinary (image uploads + optimization) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# unsigned upload preset name (browser uploads)
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- Stripe (tiered payments) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for each tier (create these in Stripe dashboard)
STRIPE_PRICE_FREE=
STRIPE_PRICE_ESSENTIAL=
STRIPE_PRICE_PREMIUM=

# --- App ---
# Secret used to sign the local session cookie (dev fallback)
APP_SECRET=change-me-to-a-long-random-string
# Public base URL of the deployed app
NEXT_PUBLIC_APP_URL=http://localhost:3000
