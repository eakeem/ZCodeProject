# ============================================================
# Memorial App — Environment Variables
# ============================================================
# Copy this file to `.env.local` and fill in your values.
# The app runs WITHOUT the optional services (local file store +
# demo login) so you can develop immediately. Set them to go live.
# ============================================================

# --- Supabase (database + storage + auth) ---
# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# anon public key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service role key (server only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=
# Storage buckets to create in the Supabase dashboard (both PUBLIC):
#   • "memorial"        — family gallery uploads
#   • "shared-photos"   — visitor-submitted photos (held for moderation)

# --- Stripe (tiered payments) — OPTIONAL ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for each tier (create these in Stripe dashboard)
STRIPE_PRICE_FREE=
STRIPE_PRICE_ESSENTIAL=
STRIPE_PRICE_PREMIUM=

# --- App ---
# Secret used to sign the session JWT (required for login).
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Legacy alias (used if JWT_SECRET is absent)
APP_SECRET=change-me-to-a-long-random-string
# Public base URL of the deployed app
NEXT_PUBLIC_APP_URL=http://localhost:3000
